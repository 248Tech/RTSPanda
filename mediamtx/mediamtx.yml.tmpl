# mediamtx config template — generated at runtime by RTSPanda.
# Do not edit this file directly; edit the Go template in internal/streams/mediamtx.go.

api: yes
apiAddress: 127.0.0.1:9997

hls: yes
hlsAddress: :8888
hlsAlwaysRemux: no
hlsSegmentCount: 3
hlsSegmentDuration: 2s
hlsPartDuration: 200ms

logLevel: warn

paths:
{{- range .Cameras}}
  camera-{{.ID}}:
    source: {{.RTSPURL}}
    sourceOnDemand: yes
    sourceOnDemandCloseAfter: 10s
{{- end}}

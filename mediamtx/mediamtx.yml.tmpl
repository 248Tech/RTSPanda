# mediamtx config reference template.
# Source of truth is backend/internal/streams/mediamtx.go (this file mirrors defaults).

api: yes
apiAddress: 127.0.0.1:9997

metrics: yes
metricsAddress: 127.0.0.1:9998

hls: yes
hlsAddress: :8888
hlsAlwaysRemux: no
hlsSegmentCount: 3
hlsSegmentDuration: 2s
hlsPartDuration: 200ms

logLevel: warn

recordPath: {{.RecordDir}}/%path/%Y-%m-%d_%H-%M-%S
recordFormat: fmp4
recordSegmentDuration: 1h

paths:
{{- range .Cameras}}
  camera-{{.ID}}:
    source: {{.RTSPURL}}
    sourceOnDemand: yes
    sourceOnDemandCloseAfter: 10s
    # Docker + some camera vendors can break UDP RTP delivery.
    # Force TCP interleaved RTP for consistent connectivity.
    rtspTransport: tcp
    rtspAnyPort: yes
    record: {{if .RecordEnabled}}yes{{else}}no{{end}}
{{- end}}
